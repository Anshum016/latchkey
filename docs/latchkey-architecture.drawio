        </mxCell>
        <mxCell id="110" value="1. Agent calls &lt;b&gt;latchkey_set_task&lt;/b&gt; at session start" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="60" y="190" width="260" height="55" as="geometry" />
        </mxCell>
        <mxCell id="111" value="2. Agent calls a protected tool like &lt;b&gt;latchkey_delete_email&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="60" y="275" width="290" height="55" as="geometry" />
        </mxCell>
        <mxCell id="112" value="3. Proxy builds RiskContext with&lt;br&gt;tool name, payload, task, call count, session age" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="290" y="275" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="113" value="4. RiskEngine scores the action:&lt;br&gt;approve / notify / block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="520" y="275" width="220" height="65" as="geometry" />
        </mxCell>
        <mxCell id="114" value="5. ApprovalService creates approval_requests row&lt;br&gt;and writes an intercepted audit event" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="735" y="255" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="115" value="Auto-approve path&lt;br&gt;mark approved by risk engine&lt;br&gt;execute upstream tool immediately" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="735" y="380" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="116" value="Notify path&lt;br&gt;send approval request with code / token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="735" y="470" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="117" value="Block path&lt;br&gt;mark auto_blocked&lt;br&gt;write audit event&lt;br&gt;do not call tool" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="735" y="560" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="118" value="6. Slack / Email delivers approval request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666666;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="995" y="470" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="119" value="7. Human replies or clicks approve / deny" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="1240" y="470" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="120" value="8. Webhook resolves by code or token&lt;br&gt;through resolvePendingDecision()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="1240" y="560" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="121" value="9. ApprovalService updates DB + audit&lt;br&gt;and waiting proxy call resumes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="995" y="560" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="122" value="10. If approved, upstream tool executes&lt;br&gt;and executed/execution_failed is audited" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=13;" vertex="1" parent="101">
          <mxGeometry x="1280" y="380" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="123" value="A denied / timed out request never reaches the upstream tool." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="101">
